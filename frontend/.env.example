# ============ Public (exposed to browser) ============

# Cronos Testnet chain ID
NEXT_PUBLIC_CHAIN_ID=338

# WalletConnect project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Pinata IPFS (https://app.pinata.cloud)
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_KEY=
NEXT_PUBLIC_PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============ Server-side (never exposed to browser) ============

# Backend wallet private key (authorized spender for credits, PKP ops)
BACKEND_PRIVATE_KEY=

# OpenAI API key (for DALL-E image gen and embeddings, optional)
OPENAI_API_KEY=

# DeepSeek API key (for agent chat — used instead of OpenAI)
DEEPSEEK_API_KEY=

# Cronos Testnet RPC
RPC_URL=https://evm-t3.cronos.org

# Lit Protocol network
LIT_NETWORK=datil-test

# ChromaDB vector database (optional - for agent memory/RAG)
CHROMA_URL=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
